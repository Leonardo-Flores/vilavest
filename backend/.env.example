# VilaVest — Environment Variables
# Copy to .env and adjust values

# ─── Server ────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# PORT is also respected (Fly.io / Render / Railway convention)

# ─── Database ──────────────────────────────────────────
# In cloud (Neon/Fly/Railway), set DATABASE_URL and ignore the DB_* vars below.
# DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require
DB_HOST=postgres
DB_PORT=5432
DB_USER=vilavest
DB_PASSWORD=vilavest_secret
DB_NAME=vilavest
DB_SSLMODE=disable

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_DAYS=7

# ─── Application ───────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:5173
# Multiple allowed origins (comma-separated) — CORS whitelist
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
